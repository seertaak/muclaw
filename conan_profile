[settings]
os=Linux
arch=x86_64
build_type=Release
*:compiler=clang
*:compiler.cppstd=23
*:compiler.libcxx=libc++
*:compiler.version=20

# Override for llama.cpp to compile with C++17
llama-cpp/*:compiler.cppstd=17

[conf]
tools.build:cflags=["-march=native", "-mavx2", "-mf16c", "-mfma"]
tools.build:cxxflags=["-march=native", "-mavx2", "-mf16c", "-mfma"]
